[label-watcher.settings]

#PDSs to watch can have multiple ones
[pds.your-pds]
host = "your-pds.com"
notifyEmails = ["admin@example.com", "another@example.com"]
# Will be used for auto take downs on down the road
pdsAdminPassword = "secure"
# Optional webhook URL for notifications
# notifyWebhookUrl = "https://example.com/webhook"
# Loads all the historic accounts in
backfillAccounts = true
# Listens for new accounts
listenForNewAccounts = true
# Send notification for new accounts
notifyOnNewAccounts = false

# Another PDS you want to watch
# [pds.your-pds-two]
# host = "your-pds-two.com"
# notifyEmails = ["admin@example.com", "another@example.com"]
# # Will be used for auto take downs on down the road
# pdsAdminPassword = "secure"
# # Loads all the historic accounts in
# backfillAccounts = true
# # Listens for new accounts
# listenForNewAccounts = true


# Define the labeler. Can do multiple labelers
[labeler.skywatch]
host = "ozone.skywatch.blue"

# Notifies if an account has elon musk in their description or display name
[labeler.skywatch.labels.elon-musk]
label_name = "elon-musk"
action = "notify"

# Notifies if an account has the platform-manipulation label applied
[labeler.skywatch.labels.platform-manipulation]
label_name = "platform-manipulation"
action = "notify"


# Define another labeler
# [labeler.hailey]
# host = "ozone.hailey.at"

#
# [labeler.hailey.labels.suss-handle-change]
# label_name = "suss-handle-change"
